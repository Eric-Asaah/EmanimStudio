<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:TPM="http://texlive.dante.de/"><rdf:Description about="http://www.miktex.org/packages/preview"><TPM:Name>preview</TPM:Name><TPM:Creator>mpc</TPM:Creator><TPM:Title>Extract bits of a LaTeX source for output</TPM:Title><TPM:Version>14.0.6</TPM:Version><TPM:TargetSystem minVersion=""></TPM:TargetSystem><TPM:Description>The package is a free-standing part of the preview-latex bundle. The package provides the support preview-latex needs, when it chooses the matter it will preview. The output may reasonably be expected to have other uses, as in html translators, etc.</TPM:Description><TPM:RunFiles size="27970">texmf\tex\latex\preview\prshowbox.def texmf\tex\latex\preview\prtightpage.def texmf\tex\latex\preview\prtracingall.def texmf\tex\latex\preview\prfootnotes.def texmf\tex\latex\preview\prcounters.def texmf\tex\latex\preview\prlyx.def texmf\tex\latex\preview\preview.sty texmf\tex\latex\preview\prauctex.def texmf\tex\latex\preview\prshowlabels.def</TPM:RunFiles><TPM:TimePackaged>1720346610</TPM:TimePackaged><TPM:MD5>7aabe59cea90a5d5595a00d40df622af</TPM:MD5><TPM:CTAN path="/macros/latex/contrib/preview"/><TPM:Copyright owner="Free Software Foundation" year="2001-2006, 2010, 2017-2024/"/><TPM:License type="gpl3"/></rdf:Description></rdf:RDF>